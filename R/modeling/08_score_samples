#!/usr/bin/env Rscript
# ============================================================
# IMRS Step 08 — Score samples (Innate activation IMRS)
# A weighted activation score measuring deviation from healthy control baseline using reproducible innate immune response genes derived from anchor datasets.
#
# Recommended settings (Option A):
# - Input: Step 5 DESeq2 normalized counts (phase-specific)
# - Transform: log2(norm + 1)
# - Z-score genes using CONTROL samples only (within dataset + phase)
# - Score ALL samples (control + delivery)
# - Genes: core genes only, excluding 6B heterogeneity_flag and 6C low_power_flag
# - Weights: beta_meta (fixed-effect), with absolute capping
#
# Outputs (per phase):
#   <project_root>/05_score/<phase>/scores/<DATASET>__IMRS_scores.tsv
#   <project_root>/05_score/<phase>/scores/<DATASET>__IMRS_gene_audit.tsv
# ============================================================

suppressPackageStartupMessages({
  library(readr)
  library(dplyr)
  library(tibble)
  library(stringr)
})

# -------------------------
# CONFIG
# -------------------------
args <- commandArgs(trailingOnly = TRUE)
project_root <- if (length(args) >= 1) args[1] else "D:/IMRS_Project"

PHASES <- c("anchor", "calibration")

# Weight handling
cap_abs_beta <- 3.0        # cap |beta_meta| to reduce dominance
min_ctrl_n   <- 2          # need >=2 controls to compute SD
sd_floor     <- 1e-8       # avoid divide-by-zero

# Locked datasets (same as Step 6)
LOCKED_DATASETS_MOUSE <- c("GSE39129", "GSE167521", "GSE264344")

# -------------------------
# Helpers: read normalized counts
# -------------------------
read_norm_counts <- function(path) {
  df <- read_tsv(path, show_col_types = FALSE)
  if (!("gene_id" %in% names(df))) {
    # step5 wrote gene_id for normalized counts
    names(df)[1] <- "gene_id"
  }
  gene_id <- as.character(df$gene_id)
  mat <- as.matrix(df %>% select(-gene_id))
  suppressWarnings(storage.mode(mat) <- "numeric")
  rownames(mat) <- gene_id
  colnames(mat) <- trimws(colnames(mat))
  mat
}

# Try to infer CONTROL/DELIVERY from full design (same idea as Step 5)
get_condition_simple_full_design <- function(design_df) {
  nm_low <- tolower(names(design_df))
  cand <- c("condition_simple", "condition", "group", "treatment", "arm")
  idx <- match(cand, nm_low)
  idx <- idx[!is.na(idx)][1]
  if (is.na(idx)) return(rep(NA_character_, nrow(design_df)))

  col <- names(design_df)[idx]
  v <- tolower(trimws(as.character(design_df[[col]])))

  out <- rep(NA_character_, length(v))
  out[str_detect(v, "control|baseline|vehicle|mock|untreat|naive|saline|pbs")] <- "CONTROL"
  out[str_detect(v, "delivery|treat|treated|infect|inj|ad5|ad26|aav|lenti|dose|vax|vacc")] <- "DELIVERY"
  out
}

read_table_robust <- function(path) {
  df <- tryCatch(read_delim(path, delim = "\t", show_col_types = FALSE, progress = FALSE),
                 error = function(e) NULL)
  if (!is.null(df) && ncol(df) > 1) return(df)

  df <- tryCatch(read_delim(path, delim = ",", show_col_types = FALSE, progress = FALSE),
                 error = function(e) NULL)
  if (!is.null(df) && ncol(df) > 1) return(df)

  df <- tryCatch(read_table(path, show_col_types = FALSE, progress = FALSE),
                 error = function(e) NULL)
  if (!is.null(df) && ncol(df) > 1) return(df)

  stop("Failed to read (delimiter/header issue): ", path)
}

# -------------------------
# Load weights for a phase
# -------------------------
load_phase_weights <- function(phase) {
  score_root <- file.path(project_root, "05_score", phase)

  core_path <- file.path(score_root, "core_gene_set.tsv")
  het_path  <- file.path(score_root, "gene_heterogeneity.tsv")
  pow_path  <- file.path(score_root, "gene_power.tsv")

  if (!file.exists(core_path)) stop("Missing core genes (Step 6A): ", core_path)
  if (!file.exists(het_path))  stop("Missing heterogeneity (Step 6B): ", het_path)
  if (!file.exists(pow_path))  stop("Missing power (Step 6C): ", pow_path)

  core <- read_tsv(core_path, show_col_types = FALSE)
  if (!("gene_id" %in% names(core))) stop("core_gene_set.tsv must contain gene_id: ", core_path)

  het <- read_tsv(het_path, show_col_types = FALSE)
  if (!all(c("gene_id","beta_meta","heterogeneity_flag") %in% names(het))) {
    stop("gene_heterogeneity.tsv missing required columns gene_id,beta_meta,heterogeneity_flag: ", het_path)
  }

  pow <- read_tsv(pow_path, show_col_types = FALSE)
  if (!all(c("gene_id","low_power_flag") %in% names(pow))) {
    stop("gene_power.tsv missing required columns gene_id,low_power_flag: ", pow_path)
  }

  w <- core %>%
    select(gene_id) %>%
    left_join(het %>% select(gene_id, beta_meta, heterogeneity_flag), by = "gene_id") %>%
    left_join(pow %>% select(gene_id, low_power_flag), by = "gene_id") %>%
    mutate(
      beta_meta = suppressWarnings(as.numeric(beta_meta)),
      heterogeneity_flag = as.logical(heterogeneity_flag),
      low_power_flag = as.logical(low_power_flag)
    ) %>%
    mutate(
      exclude = (isTRUE(heterogeneity_flag) | isTRUE(low_power_flag) | is.na(beta_meta)),
      weight_raw = beta_meta,
      weight = pmax(pmin(weight_raw,  cap_abs_beta), -cap_abs_beta)
    ) %>%
    filter(!exclude) %>%
    arrange(desc(abs(weight)))

  if (nrow(w) == 0) {
    stop("After filtering flags, no genes remain for phase=", phase,
         ". Check 6B/6C thresholds or whether core genes were produced.")
  }

  w
}

# -------------------------
# Score one dataset-phase
# -------------------------
score_one_dataset_phase <- function(dataset_id, phase, weights_df) {
  # normalized counts path (Step 5 output)
  norm_path <- file.path(project_root, "04_de", dataset_id, "normalized", phase, "gene_counts_normalized.tsv")
  if (!file.exists(norm_path)) {
    message("Skip: missing normalized counts: ", norm_path)
    return(invisible(NULL))
  }

  # design file path (for CONTROL/DELIVERY labels)
  design_path <- file.path(project_root, "00_metadata", dataset_id, paste0(dataset_id, "_design.tsv"))
  if (!file.exists(design_path)) {
    message("Skip: missing design file: ", design_path)
    return(invisible(NULL))
  }

  mat <- read_norm_counts(norm_path)
  # log transform
  expr <- log2(mat + 1)

  design <- read_table_robust(design_path)
  if (!("sample_id" %in% names(design))) {
    message("Skip: design missing sample_id: ", design_path)
    return(invisible(NULL))
  }

  design <- design %>%
    mutate(sample_id = trimws(as.character(sample_id))) %>%
    filter(sample_id %in% colnames(expr))

  if (nrow(design) == 0) {
    message("Skip: no samples overlap between design and normalized counts for ", dataset_id, " / ", phase)
    return(invisible(NULL))
  }

  cond <- get_condition_simple_full_design(design)
  design$condition_simple <- cond

  # require controls for z reference
  ctrl_ids <- design$sample_id[design$condition_simple == "CONTROL"]
  if (length(ctrl_ids) < min_ctrl_n) {
    message("Skip: < ", min_ctrl_n, " CONTROL samples for z-score reference in ",
            dataset_id, " / ", phase, " (found ", length(ctrl_ids), ")")
    return(invisible(NULL))
  }

  # align samples (design order)
  samp_ids <- design$sample_id
  expr <- expr[, samp_ids, drop = FALSE]

  # subset to weighted genes present
  genes_use <- intersect(rownames(expr), weights_df$gene_id)
  if (length(genes_use) < 5) {
    message("Skip: too few weighted genes present in expression matrix for ", dataset_id, " / ", phase,
            " (n=", length(genes_use), ")")
    return(invisible(NULL))
  }

  wsub <- weights_df %>% filter(gene_id %in% genes_use)
  expr_sub <- expr[genes_use, , drop = FALSE]

  # compute control mean/sd per gene
  ctrl_mat <- expr_sub[, ctrl_ids, drop = FALSE]
  mu <- rowMeans(ctrl_mat, na.rm = TRUE)
  sdv <- apply(ctrl_mat, 1, sd, na.rm = TRUE)
  sdv <- pmax(sdv, sd_floor)

  # drop genes with NA mu or sd (rare)
  ok_gene <- !is.na(mu) & !is.na(sdv) & is.finite(mu) & is.finite(sdv)
  expr_sub <- expr_sub[ok_gene, , drop = FALSE]
  mu <- mu[ok_gene]
  sdv <- sdv[ok_gene]
  wsub <- wsub %>% filter(gene_id %in% rownames(expr_sub))

  if (nrow(expr_sub) < 5) {
    message("Skip: too few genes after filtering NA/SD issues for ", dataset_id, " / ", phase)
    return(invisible(NULL))
  }

  # z-scores for all samples
  Z <- sweep(expr_sub, 1, mu, "-")
  Z <- sweep(Z, 1, sdv, "/")

  # weighted score: normalize by sum(|w|) so scale is comparable
  wvec <- wsub$weight
  names(wvec) <- wsub$gene_id
  wvec <- wvec[rownames(Z)]
  denom <- sum(abs(wvec))
  if (!is.finite(denom) || denom <= 0) denom <- 1

  score_raw <- as.numeric(crossprod(wvec, Z)) / denom
  names(score_raw) <- colnames(Z)

  # Standardize score using controls (QC-friendly)
  ctrl_scores <- score_raw[ctrl_ids]
  score_z <- (score_raw - mean(ctrl_scores, na.rm = TRUE)) / pmax(sd(ctrl_scores, na.rm = TRUE), sd_floor)

  out_scores <- tibble(
    sample_id = samp_ids,
    dataset_id = dataset_id,
    phase = phase,
    condition_simple = design$condition_simple,
    IMRS_raw = as.numeric(score_raw[samp_ids]),
    IMRS_z   = as.numeric(score_z[samp_ids]),
    n_genes_used = nrow(Z),
    denom_sum_abs_w = denom
  )

  # gene audit
  out_gene_audit <- wsub %>%
    mutate(
      used = gene_id %in% rownames(Z)
    ) %>%
    select(gene_id, weight_raw, weight, used)

  out_dir <- file.path(project_root, "05_score", phase, "scores")
  dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)

  write_tsv(out_scores, file.path(out_dir, paste0(dataset_id, "__IMRS_scores.tsv")))
  write_tsv(out_gene_audit, file.path(out_dir, paste0(dataset_id, "__IMRS_gene_audit.tsv")))

  message("Wrote scores: ", file.path(out_dir, paste0(dataset_id, "__IMRS_scores.tsv")),
          " | n_samples=", nrow(out_scores), " | n_genes_used=", nrow(Z))

  invisible(NULL)
}

# -------------------------
# MAIN
# -------------------------
# discover datasets present under 04_de
de_root <- file.path(project_root, "04_de")
if (!dir.exists(de_root)) stop("Missing 04_de root: ", de_root)

dataset_ids <- list.dirs(de_root, recursive = FALSE, full.names = FALSE)
dataset_ids <- dataset_ids[grepl("^GSE", dataset_ids)]

if (length(dataset_ids) == 0) stop("No datasets found under: ", de_root)

for (phase in PHASES) {
  message("\n==============================")
  message("STEP 07 PHASE: ", phase)
  message("==============================")

  weights_df <- load_phase_weights(phase)
  message("Loaded weights for phase=", phase, " | genes=", nrow(weights_df))

  for (ds in dataset_ids) {
    # You can choose to score all datasets, not just locked ones.
    # If you want to restrict to locked, uncomment:
    # if (!(ds %in% LOCKED_DATASETS_MOUSE)) next

    score_one_dataset_phase(ds, phase, weights_df)
  }
}

message("\nDONE: Step 07 scoring finished (log2(norm+1), control-z, beta_meta weights, flags applied).")
