#!/usr/bin/env Rscript
# ============================================================
# IMRS Step 06B — Heterogeneity screening (Fixed-effect, I2/Q)
# - Uses Step 5 workflow DE tables: gene, log2FC, SE, stat, pval, FDR
# - Phase-specific: anchor and calibration
# - Collapses within each dataset first (inverse-variance FE)
# - Then meta across datasets (inverse-variance FE)
# - Computes Q and I2 across DATASETS (not contrasts)
# - Computes for ALL genes, but flags heterogeneity only for core genes
#
# Outputs (per phase):
#   <project_root>/05_score/<phase>/gene_heterogeneity.tsv
# ============================================================

suppressPackageStartupMessages({
  library(readr)
  library(dplyr)
  library(stringr)
  library(purrr)
  library(tibble)
  library(tidyr)
})

# -------------------------
# USER SETTINGS
# -------------------------
args <- commandArgs(trailingOnly = TRUE)
project_root <- if (length(args) >= 1) args[1] else "D:/IMRS_Project"

de_comp_root <- file.path(project_root, "04_de", "comparison")

# Locked mouse datasets (same as your Step 6A)
LOCKED_DATASETS_MOUSE <- c("GSE39129", "GSE167521", "GSE264344")

# Run both phases
PHASES <- c("anchor", "calibration")

# Heterogeneity flag threshold (I2 >= 0.7 is common for "high heterogeneity")
I2_flag_threshold <- 0.70

# Numerical safety
se_floor <- 1e-6  # avoid division by zero
max_abs_beta <- 50 # sanity clamp for extreme log2FC values (rare; prevents overflow)

# -------------------------
# Helpers
# -------------------------
read_de_workflow_full <- function(path) {
  df <- read_tsv(path, show_col_types = FALSE)

  required <- c("gene", "log2FC", "SE", "stat", "pval", "FDR")
  missing <- setdiff(required, names(df))
  if (length(missing) > 0) {
    stop("Missing required columns in: ", path, "\nMissing: ", paste(missing, collapse = ", "))
  }

  df %>%
    transmute(
      gene_id = as.character(gene),
      beta    = suppressWarnings(as.numeric(log2FC)),
      se      = suppressWarnings(as.numeric(SE))
    ) %>%
    mutate(
      beta = pmax(pmin(beta,  max_abs_beta), -max_abs_beta),
      se   = ifelse(is.na(se), NA_real_, pmax(se, se_floor))
    )
}

get_dataset_from_path <- function(path) {
  # .../comparison/<DATASET>/deseq2_contrasts/<phase>/<file>
  parts <- strsplit(normalizePath(path, winslash = "/"), "/")[[1]]
  i <- which(parts == "comparison")
  if (length(i) == 1 && length(parts) >= i + 1) return(parts[i + 1])
  NA_character_
}

# fixed-effect meta within a group: beta_meta, se_meta, sum_w
fe_meta <- function(beta, se) {
  ok <- !is.na(beta) & !is.na(se) & se > 0
  if (!any(ok)) {
    return(list(beta = NA_real_, se = NA_real_, sum_w = 0))
  }
  w <- 1 / (se[ok]^2)
  sum_w <- sum(w)
  beta_m <- sum(w * beta[ok]) / sum_w
  se_m <- 1 / sqrt(sum_w)
  list(beta = beta_m, se = se_m, sum_w = sum_w)
}

build_6b_for_phase <- function(phase) {
  stopifnot(phase %in% c("anchor", "calibration"))

  out_root <- file.path(project_root, "05_score", phase)
  dir.create(out_root, showWarnings = FALSE, recursive = TRUE)

  # Load core gene set (if exists) for flagging
  core_path <- file.path(out_root, "core_gene_set.tsv")
  core_genes <- character(0)
  if (file.exists(core_path)) {
    core_df <- read_tsv(core_path, show_col_types = FALSE)
    if ("gene_id" %in% names(core_df)) core_genes <- as.character(core_df$gene_id)
  }

  # Collect Step 5 workflow files for this phase
  all_files <- list.files(
    de_comp_root,
    pattern = "__DE_workflow\\.tsv$",
    recursive = TRUE,
    full.names = TRUE
  )
  phase_files <- all_files[str_detect(all_files, paste0("deseq2_contrasts[\\\\/]+", phase, "[\\\\/]"))]

  if (length(phase_files) == 0) {
    message("PHASE=", phase, ": no DE_workflow files found. Skipping 6B.")
    return(invisible(NULL))
  }

  meta <- tibble(
    file = phase_files,
    dataset_id = map_chr(phase_files, get_dataset_from_path)
  ) %>%
    mutate(is_human = str_detect(dataset_id, "_HUMAN$")) %>%
    filter(
      !is_human,
      dataset_id %in% LOCKED_DATASETS_MOUSE
    )

  if (nrow(meta) == 0) {
    message("PHASE=", phase, ": found files, but none match locked mouse datasets. Skipping 6B.")
    return(invisible(NULL))
  }

  datasets_present <- sort(unique(meta$dataset_id))
  K_present <- length(datasets_present)
  if (K_present < 2) {
    stop("PHASE=", phase, ": need >=2 datasets present to compute I2/Q across datasets.\n",
         "Present: ", paste(datasets_present, collapse = ", "))
  }

  message("\n[6B] PHASE=", phase, " | datasets present: ", paste(datasets_present, collapse = ", "))

  # Long table: dataset_id, contrast_file, gene_id, beta, se
  de_long <- meta %>%
    mutate(de = map(file, read_de_workflow_full)) %>%
    tidyr::unnest(de) %>%
    mutate(contrast_file = file)

  # -------------------------
  # Collapse WITHIN dataset first:
  # For each (dataset_id, gene_id): FE meta across its contrasts -> beta_ds, se_ds
  # -------------------------
  ds_collapsed <- de_long %>%
    group_by(dataset_id, gene_id) %>%
    summarise(
      n_contrasts = n_distinct(contrast_file),
      beta_ds = fe_meta(beta, se)$beta,
      se_ds   = fe_meta(beta, se)$se,
      sum_w_ds = fe_meta(beta, se)$sum_w,
      .groups = "drop"
    ) %>%
    mutate(
      w_ds = ifelse(!is.na(se_ds) & se_ds > 0, 1/(se_ds^2), NA_real_)
    )

  # -------------------------
  # Meta ACROSS datasets:
  # For each gene: FE meta across datasets -> beta_meta, se_meta
  # Then compute Q and I2 across datasets
  # -------------------------
  gene_meta <- ds_collapsed %>%
    group_by(gene_id) %>%
    summarise(
      datasets_used = paste(sort(unique(dataset_id[!is.na(beta_ds) & !is.na(se_ds) & se_ds > 0])), collapse = ";"),
      k_datasets_used = sum(!is.na(beta_ds) & !is.na(se_ds) & se_ds > 0),
      beta_meta = fe_meta(beta_ds, se_ds)$beta,
      se_meta   = fe_meta(beta_ds, se_ds)$se,
      sum_w     = fe_meta(beta_ds, se_ds)$sum_w,
      .groups = "drop"
    )

  # Q and I2 require beta_meta per gene; compute by joining back
  gene_qi2 <- ds_collapsed %>%
    inner_join(gene_meta %>% select(gene_id, beta_meta), by = "gene_id") %>%
    filter(!is.na(beta_ds) & !is.na(se_ds) & se_ds > 0) %>%
    group_by(gene_id) %>%
    summarise(
      k = n(),  # datasets used
      Q = sum((1/(se_ds^2)) * (beta_ds - beta_meta)^2),
      df = pmax(k - 1, 0),
      I2 = dplyr::case_when(
        k < 2 ~ NA_real_,
        Q <= 0 ~ 0,
        TRUE ~ pmax(0, (Q - (k - 1)) / Q)
      ),
      .groups = "drop"
    )

  out <- gene_meta %>%
    left_join(gene_qi2, by = "gene_id") %>%
    mutate(
      phase = phase,
      is_core = gene_id %in% core_genes,
      heterogeneity_flag = ifelse(is_core & !is.na(I2) & I2 >= I2_flag_threshold, TRUE, FALSE)
    ) %>%
    arrange(desc(is_core), desc(heterogeneity_flag), desc(I2), gene_id)

  out_path <- file.path(out_root, "gene_heterogeneity.tsv")
  write_tsv(out, out_path)

  message("[6B] PHASE=", phase, ": wrote ", out_path,
          " | genes=", nrow(out),
          " | core_genes_loaded=", length(core_genes))
  invisible(NULL)
}

# -------------------------
# MAIN
# -------------------------
if (!dir.exists(de_comp_root)) {
  stop("DE comparison root not found: ", de_comp_root,
       "\nExpected: <project_root>/04_de/comparison to exist.")
}

for (ph in PHASES) {
  build_6b_for_phase(ph)
}

message("\nDONE: Step 06B heterogeneity computed (fixed-effect, dataset-collapsed) for phases: ",
        paste(PHASES, collapse = ", "))
