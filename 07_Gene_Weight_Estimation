#!/usr/bin/env Rscript
# ============================================================
# IMRS Step 07 — Gene Weight Estimation (frozen weights)
#
# Per workflow (anchors-only is the official model), but this script can also
# compute calibration weights in parallel for diagnostics.
#
# Inputs (per phase):
#   05_score/<phase>/core_gene_set.tsv
#   05_score/<phase>/gene_heterogeneity.tsv   (beta_meta, se_meta, I2)
#   05_score/<phase>/gene_power.tsv           (power, flag_low_power OR low_power_flag)
#
# Cap rule:
#   c = 95th percentile of |beta_meta| across genes in the (core) set
#   beta_capped = clamp(beta_meta, [-c, +c])
#
# Penalties:
#   penalty_het   = 1 - I2
#   penalty_power = 0.2 if power < 0.80 else 1.0
#   penalty_final = max(penalty_het * penalty_power, 0.2)
#
# Final weight:
#   weight = beta_capped * penalty_final
#
# Output (per phase):
#   05_score/<phase>/gene_weights.tsv
# ============================================================

suppressPackageStartupMessages({
  library(readr)
  library(dplyr)
  library(stringr)
  library(tibble)
})

args <- commandArgs(trailingOnly = TRUE)
project_root <- if (length(args) >= 1) args[1] else "D:/IMRS_Project"

PHASES <- c("anchor", "calibration")  # both; anchor is the official frozen model

# Pre-registered parameters
power_cutoff <- 0.80
penalty_power_low <- 0.2
penalty_floor <- 0.2
cap_quantile <- 0.95

# -------------------------
# Helpers
# -------------------------
load_core <- function(phase_root) {
  p <- file.path(phase_root, "core_gene_set.tsv")
  if (!file.exists(p)) stop("Missing core_gene_set.tsv: ", p)
  df <- read_tsv(p, show_col_types = FALSE)
  if (!("gene_id" %in% names(df))) stop("core_gene_set.tsv must contain gene_id: ", p)
  df %>% transmute(gene_id = as.character(gene_id))
}

load_heterogeneity <- function(phase_root) {
  p <- file.path(phase_root, "gene_heterogeneity.tsv")
  if (!file.exists(p)) stop("Missing gene_heterogeneity.tsv: ", p)
  df <- read_tsv(p, show_col_types = FALSE)

  # accept either I2 or i2 naming (be tolerant)
  if (!("gene_id" %in% names(df))) stop("gene_heterogeneity.tsv missing gene_id: ", p)
  if (!("beta_meta" %in% names(df))) stop("gene_heterogeneity.tsv missing beta_meta: ", p)
  if (!("se_meta" %in% names(df))) stop("gene_heterogeneity.tsv missing se_meta: ", p)

  i2_col <- if ("I2" %in% names(df)) "I2" else if ("i2" %in% names(df)) "i2" else NA_character_
  if (is.na(i2_col)) stop("gene_heterogeneity.tsv missing I2 column: ", p)

  df %>%
    transmute(
      gene_id = as.character(gene_id),
      beta_meta = suppressWarnings(as.numeric(beta_meta)),
      se_meta   = suppressWarnings(as.numeric(se_meta)),
      I2        = suppressWarnings(as.numeric(.data[[i2_col]]))
    )
}

load_power <- function(phase_root) {
  p <- file.path(phase_root, "gene_power.tsv")
  if (!file.exists(p)) stop("Missing gene_power.tsv: ", p)
  df <- read_tsv(p, show_col_types = FALSE)
  if (!("gene_id" %in% names(df))) stop("gene_power.tsv missing gene_id: ", p)

  # tolerate different column names depending on your 6C implementation
  power_col <- if ("power" %in% names(df)) "power" else if ("power_delta1" %in% names(df)) "power_delta1" else NA_character_
  if (is.na(power_col)) stop("gene_power.tsv missing power column (power or power_delta1): ", p)

  df %>%
    transmute(
      gene_id = as.character(gene_id),
      power = suppressWarnings(as.numeric(.data[[power_col]]))
    )
}

clamp <- function(x, lo, hi) pmax(pmin(x, hi), lo)

# -------------------------
# Main per-phase
# -------------------------
for (phase in PHASES) {
  phase_root <- file.path(project_root, "05_score", phase)
  if (!dir.exists(phase_root)) {
    message("PHASE=", phase, ": missing folder ", phase_root, " (skipping)")
    next
  }

  core <- load_core(phase_root)
  het  <- load_heterogeneity(phase_root)
  pow  <- load_power(phase_root)

  df <- core %>%
    left_join(het, by = "gene_id") %>%
    left_join(pow, by = "gene_id")

  # basic validity
  df <- df %>%
    filter(!is.na(beta_meta), !is.na(se_meta))

  if (nrow(df) == 0) {
    stop("PHASE=", phase, ": no valid rows after joining core+6B+6C. Check inputs in: ", phase_root)
  }

  # Cap at 95th percentile of |beta_meta| (core genes only)
  cap_c <- as.numeric(quantile(abs(df$beta_meta), probs = cap_quantile, na.rm = TRUE, names = FALSE))
  if (!is.finite(cap_c) || cap_c <= 0) {
    stop("PHASE=", phase, ": invalid cap_c computed. Check beta_meta distribution.")
  }

  df <- df %>%
    mutate(
      cap_c = cap_c,
      beta_capped = clamp(beta_meta, -cap_c, cap_c),
      capped_flag = abs(beta_meta) > cap_c,

      # penalties
      penalty_het = ifelse(is.na(I2), 1.0, pmax(0, 1 - I2)),
      penalty_power = ifelse(!is.na(power) & power < power_cutoff, penalty_power_low, 1.0),

      penalty_combined = penalty_het * penalty_power,
      penalty_final = pmax(penalty_combined, penalty_floor),

      weight = beta_capped * penalty_final
    ) %>%
    arrange(desc(abs(weight)))

  out_path <- file.path(phase_root, "gene_weights.tsv")
  out <- df %>%
    transmute(
      gene = gene_id,
      weight = weight,
      beta_meta = beta_meta,
      se_meta = se_meta,
      I2 = I2,
      power = power,
      penalty_het = penalty_het,
      penalty_power = penalty_power,
      penalty_final = penalty_final,
      beta_capped = beta_capped,
      cap_c = cap_c,
      capped_flag = capped_flag
    )

  write_tsv(out, out_path)

  message("PHASE=", phase, ": wrote ", out_path,
          " | core_genes=", nrow(out),
          " | cap_c=", signif(cap_c, 4))
}

message("\nDONE: Step 07 gene weights built. Anchor weights are the official frozen model; calibration weights are optional diagnostics.")
